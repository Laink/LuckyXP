{
  // =========================================================================
  //  DISPOSITION DE L'INTERFACE — DISTRIBUTEUR LUCKY XP (valeurs par défaut)
  //  Surchargeable via resource pack : édite, F3+T, puis RÉOUVRE la machine.
  //  Unités = pixels GUI, origine = coin haut-gauche du panneau.
  //  Couleurs = hex "AARRGGBB" (AA = opacité), entre guillemets.
  //  Une clé absente garde sa valeur par défaut ; un fichier invalide = défauts.
  // =========================================================================

  // ----- PANNEAU -----
  "panel_w": 250,                 // largeur totale du panneau
  "panel_h": 171,                 // hauteur totale
  "border": 2,                    // épaisseur de la bordure verte

  // ----- EN-TÊTE -----
  "header_type_y": 7,             // Y du nom de type (centré horizontalement)
  "header_divider_y": 19,         // Y de la ligne de séparation sous l'en-tête

  // ----- LISTE D'ARTICLES -----
  "list_top": 25,                 // Y de la 1re ligne d'article
  "row_h": 20,                    // hauteur d'une ligne
  "visible_rows": 6,              // nb de lignes visibles (au-delà -> scrollbar)
  "list_x_pad": 7,                // marge gauche/droite de la zone liste
  "icon_x": 10,                   // X de l'icône d'item
  "name_x": 33,                   // X du nom d'item
  "cost_right_pad": 2,            // marge du coût vs bord droit de la liste
  "icon_y_off": 1,                // Y de l'icône dans la ligne (monte/descend l'icône)
  "text_y_off": 6,                // Y du nom + coût dans la ligne

  // ----- PIED -----
  "footer_divider_y": 149,        // Y de la ligne de séparation au-dessus du pied
  "footer_y": 156,                // Y du texte "LUCKY LVL" + niveau

  // ----- SCROLLBAR -----
  "scrollbar_w": 6,               // largeur de la scrollbar
  "scrollbar_right_margin": 13,   // distance entre la scrollbar et le bord droit
  "scrollbar_top": 25,            // Y du haut de la scrollbar
  "scrollbar_height": 119,        // longueur du rail

  // ----- LIGNES DE BALAYAGE (effet CRT) -----
  "scan_spacing": 3,              // espacement des lignes sombres fixes
  "scan_moving": 3,               // nb de lignes vertes qui défilent
  "scan_speed": 1.1,              // vitesse de défilement

  // ----- COULEURS (AARRGGBB) -----
  "c_bg": "F0061309",             // fond du panneau (vert très sombre)
  "c_border": "FF2BBF5A",         // bordure verte
  "c_divider": "FF1F8A4D",        // lignes de séparation
  "c_txt": "FF6CF08A",            // texte vert vif (abordable)
  "c_txt_dim": "FF3C8F5A",        // texte vert atténué
  "c_txt_lock": "FF2E6B45",       // coût trop cher (+ cadenas)
  "c_hover": "335CF08A",          // surbrillance de ligne au survol
  "c_scan_dark": "1A000000",      // lignes de balayage sombres
  "c_scan_line": "335CF08A",      // lignes vertes qui défilent
  "c_sb_track": "FF0C2A18",       // rail de la scrollbar
  "c_sb_thumb": "FF2BBF5A",       // curseur de la scrollbar

  // ----- BADGE DE RARETÉ (pied, à droite) -----
  "rarity_text_x": 230,           // bord DROIT du texte (aligné à droite -> gère la longueur variable)
  "rarity_text_y": 156,           // Y du texte de rareté
  "rarity_pill_x": 238,           // X du centre de la pastille clignotante
  "rarity_pill_y": 159,           // Y du centre de la pastille
  "rarity_pill_radius": 3,        // rayon de la pastille
  "rarity_pill_speed": 0.22       // vitesse de clignotement
}
